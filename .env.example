# ── Railway Deployment ──────────────────────────────────────────────────────
# When deploying to Railway, DATABASE_URL and REDIS_URL are auto-injected
# when you link PostgreSQL and Redis services. Override DATABASE_URL with:
#   ${{Postgres.DATABASE_URL | replace("postgresql://", "postgresql+asyncpg://")}}
# See DEPLOY.md for full setup instructions.

# GitHub — use one of: GitHub App (recommended) OR Personal Access Token (quick start)
# GitHub App:
# GITHUB_APP_ID=123456
# GITHUB_APP_PRIVATE_KEY_PATH=/secrets/github-app.pem
# Personal Access Token:
GITHUB_TOKEN=ghp_xxxxxxxxxxxx

GITHUB_WEBHOOK_SECRET=your-webhook-hmac-secret
GITHUB_DEFAULT_BRANCH=main

# Database (Railway auto-injects this when PostgreSQL is linked)
DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/codebase_intel

# Redis (Railway auto-injects this when Redis is linked)
REDIS_URL=redis://localhost:6379

# Embeddings (Voyage AI)
VOYAGE_API_KEY=pa-xxxxxxxxxxxx
EMBEDDING_MODEL=voyage-code-2
EMBEDDING_DIMENSIONS=1024

# LLM (optional demo chat)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxx
OPENAI_API_KEY=sk-xxx
# MCP Auth
JWT_SECRET=your-jwt-signing-secret
GITHUB_OAUTH_CLIENT_ID=your-oauth-app-client-id
GITHUB_OAUTH_CLIENT_SECRET=your-oauth-app-client-secret
#Hosted URL
PUBLIC_BASE_URL=http://localhost:8000

# Indexing config
CHUNK_TARGET_TOKENS=512
CHUNK_OVERLAP_TOKENS=128
CONTEXT_TOKEN_BUDGET=8000
SUPPORTED_EXTENSIONS=.py,.ts,.tsx,.js,.java,.go,.rs,.cpp,.c,.cs,.rb,.swift,.kt
IGNORE_PATTERNS=node_modules,.git,__pycache__,.venv,dist,build,.next,*.min.js
